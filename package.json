{
  "name": "covid19vaccinetracker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:serve": "electron-vite dev",
    "electron:preview": "electron-vite preview",
    "electron:build": "electron-vite build && electron-builder",
    "electron:build-windows": "electron-vite build && electron-builder --win nsis",
    "electron:build-linux": "electron-vite build && electron-builder --linux deb"
  },
  "main": "out/main/index.js",
  "author": "Ssewannonda Keith Edwin",
  "description": "A Covid-19 vaccine tracker app",
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.18.1",
    "roboto-fontface": "^0.10.0",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vuetify": "^4.1.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "sass-embedded": "^1.100.0",
    "vite": "^7.3.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "build": {
    "appId": "com.edcsu.covid19vaccinetracker",
    "productName": "Covid-19 Vaccine Tracker App",
    "files": [
      "out/**"
    ],
    "directories": {
      "output": "dist_electron"
    }
  }
}
